---
import "../styles/global.css";
const { title = "Astro Security Lab" } = Astro.props;
---

<html lang="sv">
    <head>
        <meta charset="utf-8" />
        <meta
            name="viewport"
            content="width=device-width"
        />
        <title>{title}</title>
    </head
    ><body>
        <main class="wrap">
            <h1>{title}</h1>
            <nav>
                <a href="/">Start</a>
                <a href="/vulnerable">Sårbar version</a>
                <a href="/protected">Skyddad version</a>
                <a href="/attacks/xss">XSS-test</a>
                <a href="/attacks/csrf">CSRF-test</a>
                <a href="/attacks/clickjacking">Clickjacking-test</a>
            </nav>
            <slot />
        </main>
    </body>
</html>
